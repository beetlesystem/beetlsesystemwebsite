Options -MultiViews -Indexes
RewriteEngine On
RewriteBase /beetlesystem/

# Handle real files/folders
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 1. Main Direct Mappings
RewriteRule ^$ index.php [L]
RewriteRule ^home/?$ index.php [L]
RewriteRule ^about/?$ view/about.php [L]
RewriteRule ^services/?$ view/services.php [L]
RewriteRule ^projects/?$ view/projects.php [L]
RewriteRule ^contact/?$ view/contact.php [L]

# 2. Admin Mappings
RewriteRule ^dashboard/?$ controller/dashboard/index.php [L]
RewriteRule ^admin/?$ controller/index.php [L]
RewriteRule ^register/?$ controller/register.php [L]
RewriteRule ^admin/projects/?$ controller/projects/index.php [L]
RewriteRule ^admin/contacts/?$ controller/contacts/index.php [L]
RewriteRule ^admin/testimonials/?$ controller/testimonials/index.php [L]
RewriteRule ^admin/visitors/?$ controller/visitors/index.php [L]
RewriteRule ^admin/clients/?$ controller/clients/index.php [L]
RewriteRule ^admin/cms/?$ controller/cms/index.php [L]
# 3. Handle Root PHP files as fallback
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

# 4. Handle View PHP files as fallback
RewriteCond %{DOCUMENT_ROOT}/beetlesystem/view/$1.php -f
RewriteRule ^([^/]+)/?$ view/$1.php [L]

# 404 Error page to confirm .htaccess is working
ErrorDocument 404 /beetlesystem/index.php
